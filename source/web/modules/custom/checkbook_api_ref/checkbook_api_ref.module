/**
 * Implements hook_cron().
 */
function checkbook_api_ref_cron() {
  LogHelper::log_notice("Running checkbook_api_ref_cron");
  $CES = new \Drupal\checkbook_api_ref\API\CheckbookApiRef();
  return $CES->api_ref_cron();
}

/**
 * Implements hook_mail().
 * @param $key
 * @param $message
 * @param $params
 */
function checkbook_api_ref_mail($key, &$message, $params) {
  $CES = new \Drupal\checkbook_api_ref\API\CheckbookApiRef();
  $CES->gatherData($message);
  $message['body'] = array_merge($message['body'], $params);
  //Declare this as HTML mail EARLY
  $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';
  //$message['body'] = [''];
}

/**
 * Implements hook_mail_alter().
 *
 * Adds priority headers to messages passing condition.
 * @param $message
 * @throws Exception
 */
function checkbook_api_ref_mail_alter(&$message) {
  // Apply this hook only for `checkbook_api_ref` module
  if ('checkbook_api_ref' !== $message['module']) {
    return;
  }

  if (stripos($message['subject'], 'Fail') || stripos($message['subject'], 'not Found')) {
    $message['headers']['X-Priority'] = '1 (Highest)';
    $message['headers']['X-MSMail-Priority'] = 'High';
    $message['headers']['Importance'] = 'High';
  }

  // Force HTML email.
  $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';

  // Debug: Log what we receive
  \Drupal::logger('checkbook_api_ref')->debug('Message body before rendering: @body', [
    '@body' => print_r($message['body'], TRUE)
  ]);

  // Check if body is already an array with our data structure
  if (is_array($message['body']) && isset($message['body']['status'])) {
    // Body already has the structure we need
    $body_data = [
      '#theme' => 'api-ref-mail',
      '#message' => $message['body'],
    ];
  } else {
    // Body might be a simple array of strings, extract from params
    $body_data = [
      '#theme' => 'api-ref-mail',
      '#message' => $message['params'] ?? [],
    ];
  }

  // Render to raw HTML string.
  $html = \Drupal::service('renderer')->renderPlain($body_data);

  // Mail body MUST be an array of safe strings.
  $message['body'] = [
    Markup::create($html),
  ];
}

/**
 * Implements hook_theme()
 * @param $existing
 * @param $type
 * @param $theme
 * @param $path
 * @return array
 */
function checkbook_api_ref_theme($existing, $type, $theme, $path) {
  return [
    'api-ref-mail'=>[
      'template'=>'api-ref.email',
      'variables' => [
        'file_generation_status' => NULL,
        'message' => []
      ],
    ],
  ];
}
